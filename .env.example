# SEC Scanner — Railway environment variables
# Copy these into Railway's "Variables" tab for this service

PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_APP_TOKEN=your_pushover_app_token

# Must match your real email — SEC requires this in the User-Agent header
SEC_USER_AGENT=SECScanner/1.0 your@email.com

# Optional: POST confirmation back to your Execution-Wall8 app
# Leave blank to disable
EXECUTION_APP_CALLBACK_URL=https://your-execution-app.up.railway.app/api/webhook
